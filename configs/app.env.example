# App runtime
MIRA_HOST=0.0.0.0
MIRA_PORT=8080
MIRA_REQUEST_TIMEOUT_S=20
MIRA_MAX_INPUT_CHARS=16000
MIRA_MAX_OUTPUT_TOKENS=512
MIRA_MIN_OUTPUT_TOKENS=1

# Upstream LLM provider (optional)
MIRA_LLM_BASE_URL=
MIRA_LLM_API_KEY=
MIRA_LLM_MODEL=

# Tracking and safety
MIRA_ENABLE_ANALYTICS=false
MIRA_STRICT_JSON_MODE=true
