# App runtime
MIRA_HOST=0.0.0.0
MIRA_PORT=8080
MIRA_REQUEST_TIMEOUT_S=20
MIRA_API_KEY=
MIRA_MAX_INPUT_CHARS=16000
MIRA_MAX_OUTPUT_TOKENS=512
MIRA_MIN_OUTPUT_TOKENS=1

# Upstream LLM provider (optional)
MIRA_LLM_BASE_URL=
MIRA_LLM_API_KEY=
MIRA_LLM_MODEL=
MIRA_UPSTREAM_CHAT_ENDPOINT=/v1/chat/completions
MIRA_PROVIDER_TEMPERATURE=0.1
MIRA_FORCE_FALLBACK=false

# Tracking and safety
MIRA_STRICT_JSON_MODE=true
