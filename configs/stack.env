# Stack networking
VLLM_BIND_ADDRESS=127.0.0.1
VLLM_PUBLIC_PORT=8000
CANARY_PROXY_BIND_ADDRESS=127.0.0.1
CANARY_PROXY_PUBLIC_PORT=8003
MIRA_API_BIND_ADDRESS=0.0.0.0
MIRA_API_PORT=8080

# Base model and serving
BASE_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
BASE_MODEL_NAME=qwen2.5-7b-instruct
CANARY_MODEL_NAME=qwen2.5-7b-instruct-edu-lora
VLLM_DTYPE=bfloat16
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.92
VLLM_MAX_NUM_SEQS=64
VLLM_MAX_NUM_BATCHED_TOKENS=8192
VLLM_API_KEY=
VLLM_EXTRA_ARGS=

# Canary routing
CANARY_PERCENT=10
CANARY_HASH_HEADER=x-canary-key
ENABLE_GUARDRAILS=true
PROXY_TIMEOUT_S=60

# Mira API
MIRA_HOST=0.0.0.0
MIRA_PORT=8080
MIRA_API_KEY=
MIRA_REQUEST_TIMEOUT_S=30
MIRA_MAX_INPUT_CHARS=24000
MIRA_MAX_OUTPUT_TOKENS=1024
MIRA_MIN_OUTPUT_TOKENS=1
MIRA_LLM_BASE_URL=http://llm-canary-proxy:8003
MIRA_LLM_API_KEY=
MIRA_LLM_MODEL=qwen2.5-7b-instruct
MIRA_UPSTREAM_CHAT_ENDPOINT=/v1/chat/completions
MIRA_PROVIDER_TEMPERATURE=0.05
MIRA_FORCE_FALLBACK=false
MIRA_STRICT_JSON_MODE=true

# Storage layout
MODEL_MOUNT_PATH=/models
HF_HOME=/workspace/.hf_cache
HUGGINGFACE_HUB_CACHE=/workspace/.hf_cache/hub
